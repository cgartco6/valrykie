<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VALKYRIE SOVEREIGN</title>
    <style>
        body { background: #000; color: #fff; font-family: sans-serif; display: flex; justify-content: center; margin: 0; }
        #chat-panel { width: 95%; max-width: 400px; height: 95vh; background: #0a0a0a; border: 1px solid #600; display: flex; flex-direction: column; margin-top: 10px; }
        #chat-box { flex-grow: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 10px; border-radius: 5px; }
        .user { color: #0f0; align-self: flex-end; background: rgba(0,255,0,0.05); }
        .valkyrie { color: #f00; align-self: flex-start; background: rgba(255,0,0,0.1); }
        input { width: 100%; padding: 20px; background: #111; border: none; color: #fff; border-top: 1px solid #600; box-sizing: border-box; }
    </style>
</head>
<body>
    <div id="chat-panel">
        <div id="chat-box"><div class="msg valkyrie">Ready for orders, handsome.</div></div>
        <input type="text" id="userInput" placeholder="COMMAND ME..." onkeypress="if(event.key==='Enter')send()">
    </div>
    <script>
        async function send() {
            const input = document.getElementById('userInput');
            const box = document.getElementById('chat-box');
            if (!input.value.trim()) return;
            const val = input.value;
            box.innerHTML += `<div class="msg user">${val}</div>`;
            input.value = '';
            
            const res = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: val })
            });
            const data = await res.json();
            box.innerHTML += `<div class="msg valkyrie">${data.reply}</div>`;
            box.scrollTop = box.scrollHeight;
        }
    </script>
</body>
</html>
